# Copy to .env and fill in. NEVER commit the real .env.
# Fireworks AI — get the key at https://app.fireworks.ai (API Keys)
FIREWORKS_API_KEY=
# Model id from the hackathon's revealed list. Gemma example form:
# FIREWORKS_MODEL=accounts/fireworks/models/<gemma-model-id>
FIREWORKS_MODEL=

# Optional: point at any OpenAI-compatible endpoint instead of Fireworks.
# Dev-testing example with local Ollama (set FIREWORKS_API_KEY=ollama and
# FIREWORKS_MODEL to your local model name, e.g. gemma3):
# FIREWORKS_BASE_URL=http://localhost:11434/v1
# FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1  (default)
